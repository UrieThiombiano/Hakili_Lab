<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <title>{{ DOC_TITLE }} — {{ STUDENT_NAME }}</title>
  <style>
    /* ===== PAGE ===== */
    @page {
      size: A4;
      margin-top: 28mm;
      margin-left: 20mm;
      margin-right: 18mm;
      margin-bottom: 22mm;

      @frame header_frame {
        -pdf-frame-content: page_header;
        left: 20mm; width: 172mm; top: 7mm; height: 16mm;
      }
      @frame footer_frame {
        -pdf-frame-content: page_footer;
        left: 20mm; width: 172mm; bottom: 5mm; height: 10mm;
      }
    }

    /* ===== BASE ===== */
    * { box-sizing: border-box; }
    body {
      font-family: {{ FONT_NAME }}, Helvetica, sans-serif;
      font-size: 10.5pt;
      color: #1a1a1a;
      line-height: 1.55;
    }
    p { margin: 0 0 4pt 0; }

    /* ===== EN-TÊTE / PIED DE PAGE ===== */
    .hdr-left   { font-size: 9pt; font-weight: bold; color: #1A5276; padding: 0; }
    .hdr-center { font-size: 8pt; color: #5D6D7E; text-align: center; padding: 0; }
    .hdr-right  { font-size: 8pt; color: #5D6D7E; text-align: right; padding: 0; }

    /* ===== BANDEAU ÉLÈVE ===== */
    .banner {
      background-color: #1A5276;
      border-bottom: 3pt solid #C0392B;
      padding: 12pt 16pt;
      text-align: center;
      margin-bottom: 12pt;
    }
    .banner-name { font-size: 17pt; font-weight: bold; color: white; margin-bottom: 3pt; }
    .banner-sub  { font-size: 9pt; color: #aad4f5; }

    /* ===== INFO BOX ===== */
    .info-box {
      background: #EAF2FF;
      border-left: 3pt solid #2E86C1;
      padding: 6pt 10pt;
      margin-bottom: 18pt;
      font-size: 9pt;
    }

    /* ===== SÉRIE ===== */
    .serie-title {
      background-color: #1A5276;
      color: white;
      font-weight: bold;
      font-size: 10pt;
      padding: 5pt 10pt;
      margin-top: 20pt;
      margin-bottom: 0;
      letter-spacing: 0.2pt;
    }
    .serie-rule {
      border-top: 2pt solid #C0392B;
      margin-bottom: 12pt;
    }

    /* ===== EXERCICE ===== */
    .exo-block {
      margin-bottom: 18pt;
      page-break-inside: avoid;
    }
    .exo-title {
      font-size: 11pt;
      font-weight: bold;
      font-style: italic;
      color: #1A5276;
      border-bottom: 0.8pt solid #AED6F1;
      padding-bottom: 3pt;
      margin-bottom: 8pt;
    }

    /* ===== ÉNONCÉ (contexte du problème) ===== */
    .enonce-block {
      background: #F4F6F7;
      border-left: 3pt solid #808B96;
      padding: 7pt 12pt;
      margin-bottom: 9pt;
      font-size: 10.5pt;
    }

    /* ===== TÂCHES NUMÉROTÉES ===== */
    .tasks-wrap { margin-bottom: 9pt; }
    .task-row { width: 100%; border-collapse: collapse; margin-bottom: 0; }
    .task-num  {
      width: 22pt;
      vertical-align: top;
      font-weight: bold;
      color: #1A5276;
      font-size: 10.5pt;
      padding: 4pt 6pt 4pt 0;
    }
    .task-text {
      vertical-align: top;
      font-size: 10.5pt;
      padding: 4pt 0;
      border-top: 0.3pt solid #E5E8EA;
    }
    .task-text-first {
      vertical-align: top;
      font-size: 10.5pt;
      padding: 0 0 4pt 0;
    }
    .task-num-first {
      width: 22pt;
      vertical-align: top;
      font-weight: bold;
      color: #1A5276;
      font-size: 10.5pt;
      padding: 0 6pt 4pt 0;
    }

    /* ===== INDICE ===== */
    .hint-box {
      border: 0.5pt dashed #D4AC0D;
      background: #FEFAF2;
      padding: 5pt 9pt;
      margin-top: 6pt;
      font-size: 8.5pt;
      font-style: italic;
      color: #7D6608;
    }

    /* ===== ESPACE RÉPONSE ===== */
    .answer-space {
      border: 0.5pt solid #C8CBD0;
      background: #FAFAFA;
      height: 32mm;
      margin-top: 8pt;
    }

    /* ===== PIED DE DOCUMENT ===== */
    .doc-footer {
      margin-top: 22pt;
      border-top: 0.5pt solid #ddd;
      padding-top: 5pt;
      text-align: center;
      font-size: 8pt;
      color: #7f8c8d;
      font-style: italic;
    }
  </style>
</head>
<body>

<!-- ── EN-TÊTE DE PAGE ──────────────────────────────────────────── -->
<div id="page_header">
  <table style="width:100%; border-collapse:collapse;">
    <tr>
      <td class="hdr-left">HAKILI LAB</td>
      <td class="hdr-center">{{ DOC_TITLE }}</td>
      <td class="hdr-right">Page <pdf:pagenumber/> / <pdf:pagecount/></td>
    </tr>
  </table>
  <hr style="border:0; border-top:1.4pt solid #C0392B; margin-top:3pt;"/>
</div>

<!-- ── PIED DE PAGE ─────────────────────────────────────────────── -->
<div id="page_footer">
  <hr style="border:0; border-top:0.5pt solid #ccc;"/>
  <p style="text-align:center; font-size:7.5pt; color:#7f8c8d; margin:2pt 0 0 0;">
    Hakili Lab &nbsp;&#8226;&nbsp; Document confidentiel &nbsp;&#8226;&nbsp; Usage pédagogique exclusif
  </p>
</div>

<!-- ── BANDEAU ──────────────────────────────────────────────────── -->
<div class="banner">
  <div class="banner-name">{{ STUDENT_NAME }}</div>
  <div class="banner-sub">{{ DOC_TITLE }} — {{ DATE }}</div>
</div>

<!-- ── INFO ─────────────────────────────────────────────────────── -->
<div class="info-box">
{% if is_enrichment %}
  <strong>{{ total }} exercice{% if total > 1 %}s{% endif %} d'approfondissement</strong>
  — niveau 2nde / 1ère scientifique. {{ DOC_SUBTITLE }}
  Résous chaque exercice sans aide extérieure.
{% else %}
  <strong>{{ total }} exercice{% if total > 1 %}s{% endif %} de remédiation</strong>
  répartis en {{ series|length }} série{% if series|length > 1 %}s{% endif %}.
  Ces exercices ciblent les lacunes identifiées lors de la correction.
  Travaille chaque série dans l'ordre indiqué.
{% endif %}
</div>

<!-- ── SÉRIES D'EXERCICES ────────────────────────────────────────── -->
{% for serie in series %}

<div class="serie-title">Série {{ serie.idx }} — {{ serie.topic }}</div>
<div class="serie-rule"></div>

{% for ex in serie.exercises %}
<div class="exo-block">

  <!-- Titre de l'exercice -->
  <div class="exo-title">Exercice {{ ex.number }}</div>

  <!-- Énoncé (contexte du problème) — affiché si non vide -->
  {% if ex.enonce %}
  <div class="enonce-block">{{ ex.enonce }}</div>
  {% endif %}

  <!-- Questions numérotées -->
  {% if ex.has_tasks %}
  <div class="tasks-wrap">
    {% for task in ex.tasks %}
    <table class="task-row">
      <tr>
        {% if loop.first %}
        <td class="task-num-first">{{ loop.index }}.</td>
        <td class="task-text-first">{{ task }}</td>
        {% else %}
        <td class="task-num">{{ loop.index }}.</td>
        <td class="task-text">{{ task }}</td>
        {% endif %}
      </tr>
    </table>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Indice -->
  {% if ex.has_hint %}
  <div class="hint-box">&#128161;&nbsp; <em>Indice : {{ ex.hint }}</em></div>
  {% endif %}

  <!-- Espace réponse -->
  <div class="answer-space"></div>

</div>
{% endfor %}

{% endfor %}

<!-- ── PIED DE DOCUMENT ──────────────────────────────────────────── -->
<div class="doc-footer">
  Feuille générée par Hakili Lab IA — Utilisée dans le cadre d'un suivi pédagogique personnalisé.
</div>

</body>
</html>
