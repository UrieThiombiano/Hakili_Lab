# Copiez ce fichier en secrets.toml pour le dev local (jamais commité)
# Sur Streamlit Cloud : coller ces valeurs dans Settings → Secrets

ANTHROPIC_API_KEY = "sk-ant-..."
GOOGLE_API_KEY = ""
DEEPSEEK_API_KEY = ""
MISTRAL_API_KEY = ""

CLAUDE_MODEL_HEAVY = "claude-sonnet-4-6"
CLAUDE_MODEL_LIGHT = "claude-haiku-4-5-20251001"
CLAUDE_MODEL_OPUS = "claude-opus-4-7"
GEMINI_MODEL = "gemini-2.5-flash"

VISION_PROVIDER = "claude"       # "gemini" | "claude"
GRADING_PROVIDER = "claude"      # "deepseek" | "claude"
DIAGNOSTIC_PROVIDER = "claude"   # "deepseek" | "mistral" | "claude"
REMEDIATION_PROVIDER = "claude"  # "mistral" | "deepseek" | "claude"

RUNS_DIR = "/tmp/hakili_runs"
